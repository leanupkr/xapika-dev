# =============================================================================
# Xapika Engineering — Environment Variables (template)
# =============================================================================
# Copy this file to `.env.local` (Git-ignored) and fill in the values.
# All variables are optional in development; the site runs without them but
# loses some functionality. See README.md → "Environment Variables" for details.
# =============================================================================


# -----------------------------------------------------------------------------
# Site URL — used by sitemap, OG image, JSON-LD canonicals
# -----------------------------------------------------------------------------
# Defaults to https://xapika-dev.vercel.app when unset. Set to your preview /
# staging / production origin so absolute URLs resolve correctly.
#
# Vercel auto-injects VERCEL_URL but does NOT set this — set it explicitly in
# the Vercel project's "Environment Variables" panel.

NEXT_PUBLIC_SITE_URL=https://xapika-dev.vercel.app


# -----------------------------------------------------------------------------
# Resend — Contact form email delivery
# -----------------------------------------------------------------------------
# 1) Create a Resend API key:    https://resend.com/api-keys
# 2) Verify the sending domain (xapika.pl) in Resend, configure SPF / DKIM DNS.
# 3) Fill in the values below.
#
# Without RESEND_API_KEY the contact form still works — submissions are
# accepted and validated, but no email is delivered (the server logs them).

RESEND_API_KEY=

# Sender shown in the recipient inbox. Must be on a domain you've verified in
# Resend, otherwise delivery will fail. Default falls back to a non-routable
# placeholder so missing config doesn't crash the build.
CONTACT_FROM_EMAIL="Xapika Contact <noreply@xapika.pl>"

# Where contact form submissions are delivered.
CONTACT_TO_EMAIL=info@xapika.pl

# Optional CC. Leave blank to disable.
CONTACT_CC_EMAIL=


# -----------------------------------------------------------------------------
# Analytics & Monitoring (placeholders — not yet wired into the codebase)
# -----------------------------------------------------------------------------
# Vercel Analytics + Speed Insights are mounted automatically when the project
# is deployed on Vercel — no key needed.
#
# The variables below are reserved for future integrations referenced in the
# PRD. They are currently NOT consumed by any code path; setting them has no
# effect until the corresponding integration ships.

# Sentry (error monitoring) — pending integration
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# NEXT_PUBLIC_SENTRY_DSN=

# Google Analytics 4 — pending integration
# NEXT_PUBLIC_GA4_ID=

# reCAPTCHA v3 (contact form) — pending integration
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
