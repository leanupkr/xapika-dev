# =============================================================================
# Resend — Contact form email delivery
# =============================================================================
# 1) Create a Resend API key:    https://resend.com/api-keys
# 2) Verify the sending domain (xapika.pl) in Resend, configure SPF/DKIM DNS.
# 3) Copy this file to `.env.local` and fill in the values below.
#
# Without RESEND_API_KEY the contact form still works in dev/preview — submissions
# are accepted and logged server-side, but no email is delivered.
# =============================================================================

RESEND_API_KEY=

# Sender shown in the recipient inbox. Must be on a domain you've verified in
# Resend, otherwise delivery will fail. Default falls back to a non-routable
# placeholder so missing config doesn't crash the build.
CONTACT_FROM_EMAIL="Xapika Contact <noreply@xapika.pl>"

# Where contact form submissions are delivered.
CONTACT_TO_EMAIL=info@xapika.pl

# Optional CC. Leave blank to disable.
CONTACT_CC_EMAIL=
